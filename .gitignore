# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
env/
.env
*.egg-info/
.eggs/
dist/
build/
pip-wheel-metadata/

# --- Tests / tooling ---
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# --- IDE / OS ---
.idea/
.vscode/
*.swp
.DS_Store
Thumbs.db
.cursor/

# --- ML weights & downloads (large; train locally or place manually) ---
*.pth
*.onnx
*.pt
*.ckpt
*.safetensors
assets/*.task
assets/*.pth
assets/training_metrics.jsonl
assets/last_run_summary.json
hub/
checkpoints/

# --- Face images & local datasets (never commit photos) ---
# Put Kaggle extracts and your own photos under data/faces/ — see data/faces/README.md
data/faces/*
!data/faces/README.md
!data/faces/.gitkeep

# --- Archives & dumps ---
*.zip
*.tar
*.tar.gz
*.7z
*.rar

# --- Logs ---
*.log
wandb/
